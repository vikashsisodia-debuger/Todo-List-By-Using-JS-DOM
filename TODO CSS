    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }
        body{
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background:linear-gradient(135deg,#5f2c82,#49a09d);
        }
        .container{
            width: 500px;
            min-height: 500px;
            background:rgba(255,255,255,0.12);
            backdrop-filter:blur(10px);
            border-radius:20px;
            padding:25px;
            box-shadow:0 0 20px rgba(0,0,0,0.3);
        }
        h1{
            text-align: center;
            color: white;
            margin-bottom: 20px;
        }
        .inputBox{
            display: flex;
            justify-content: space-between;
        }
        #input{
            width: 75%;
            height: 50px;   
            border: none;
            outline: none;
            border-radius: 15px;
            padding-left: 15px;
            font-size: 18px;
        }
        #addBtn{
            width: 20%;
            border: none;
            border-radius: 15px;
            cursor: pointer;
            font-size: 18px;
            background: #00e676;
            color: white;
            transition: 0.3s;
        }
        #addBtn:hover{
            transform: scale(1.05);
        }
        .taskButtons{
            display: flex;
            gap: 10px;
        }
        .doneBtn{
            background: #00c853;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
        }
        .deleteBtn{
            background: #ff1744;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
        }
        .completed{
            text-decoration: line-through;
            color: gray;
        }
        #taskList{
            margin-top: 20px;
        }
        li{
            list-style: none;
            background: white;
            margin-top: 12px;
            border-radius: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            font-size: 18px;
        }
    </style>
